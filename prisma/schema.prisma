// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PEGAWAI
  SDM_DIVISION
}

enum Currency {
  IDR
  USD
}

enum PerdinStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username       String          @unique
  password       String
  role           Role            @default(PEGAWAI)
  perdinRequests PerdinRequest[]

  @@map("users")
}

model PerdinRequest {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String       @map("user_id") @db.Uuid
  user              User         @relation(fields: [userId], references: [id])
  destinationCityId String       @map("destination_city_id") @db.Uuid
  originCityId      String       @map("origin_city_id") @db.Uuid
  arrivalDate       DateTime     @map("arrival_date") @db.Date
  departureDate     DateTime     @map("departure_date") @db.Date
  status            PerdinStatus @default(PENDING)
  destinationCity   City         @relation("DestinationCity", fields: [destinationCityId], references: [id])
  originCity        City         @relation("OriginCity", fields: [originCityId], references: [id])
  currency          Currency?    @default(IDR)

  totalKm    Int?     @map("total_km")
  totalDay   Int?     @map("total_day")
  travelCost Decimal? @map("travel_cost") @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("perdin_requests")
}

model City {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String  @unique
  provinceId String  @map("province_id") @db.Uuid
  islandId   String  @map("island_id") @db.Uuid
  longitude  Float
  latitude   Float
  is_abroad  Boolean @default(false)

  province                 Province        @relation(fields: [provinceId], references: [id])
  originPerdinRequest      PerdinRequest[] @relation("DestinationCity")
  destinationPerdinRequest PerdinRequest[] @relation("OriginCity")
  island                   Island          @relation(fields: [islandId], references: [id])

  @@map("cities")
}

model Province {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name   String @unique
  cities City[]

  @@map("provinces")
}

model Island {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @unique
  City City[]

  @@map("islands")
}
